# Block web access to the git metadata folder (the site is deployed via
# `git pull` into the web root, so .git lives here — don't let it be served).
RedirectMatch 404 /\.git

# --- Cache policy ----------------------------------------------------------
# The app is a PWA behind Cloudflare. The service worker, HTML, manifest, and
# the JS/CSS that make up the app shell must NEVER be cached by the browser or
# the CDN, otherwise updates won't reach devices (and you'd have to clear the
# cache by hand). Media (gifs/images) rarely changes, so cache it hard.
<IfModule mod_headers.c>
  # App code & shell — always revalidate, never store.
  <FilesMatch "\.(html|js|css|webmanifest)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header unset Expires
    Header set Expires "0"
  </FilesMatch>
  # Static media — safe to cache for a long time.
  <FilesMatch "\.(gif|webp|svg|png|jpe?g|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Also drop server-driven Expires headers for app code if mod_expires is on.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType text/javascript "access plus 0 seconds"
  ExpiresByType text/css "access plus 0 seconds"
  ExpiresByType application/manifest+json "access plus 0 seconds"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
</IfModule>
